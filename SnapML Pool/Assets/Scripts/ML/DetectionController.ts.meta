  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">DetectionController – bounding box visualization</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Instantiates and positions overlay objects for each ML detection on screen.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Scene References</span>"}'
    - '// @input Component.Image debugImage {"hint":"Debug image overlay rendered on top of the camera feed"}'
    - '// @input SceneObject objectToCopy {"hint":"Scene object used as the template for each detection overlay"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Detection Settings</span>"}'
    - '// @input float maxCount = 70 {"hint":"Maximum number of simultaneous detection overlays to instantiate", "widget":"slider", "min":0, "max":100, "step":1}'
    - '// @input bool setObjectPosition = true {"hint":"Move each overlay object to match its corresponding detection position"}'
    - '// @input bool matchDetections {"hint":"Match current detections to those from the previous frame to reuse scene objects"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Match Settings</span>", "showIf":"matchDetections"}'
    - '// @input float matchThreshold = 0.5 {"hint":"IoU threshold below which an unmatched detection persists for lostFrameThreshold updates", "widget":"slider", "min":0, "max":0.95, "step":0.05}'
    - '// @input float lostFramesThreshold = 4 {"hint":"Number of update frames a lost detection remains active before being removed", "widget":"slider", "min":0, "max":10, "step":1, "showIf":"matchDetections"}'
    - '// @input float smoothCoef {"hint":"Smoothing coefficient applied to detection position interpolation", "widget":"slider", "min":0, "max":1, "step":0.01, "showIf":"matchDetections"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
