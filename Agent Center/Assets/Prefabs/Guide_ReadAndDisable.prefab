- !<ObjectPrefab/6a53b779-fc40-443f-abe4-3e454a46ccf1>
  PackagePath: ""
  objects:
    - !<own> 330d0451-4512-4a28-8c9a-92f766ac896b
  LazyLoading: false
  RetainAssets: true
- !<Text/0327abd6-dfc9-45eb-8d11-62291ff89551>
  PrefabRemaps:
    []
  Name: Text
  Enabled: true
  RenderOrder: 999
  StretchMode: Stretch
  VerticalAlignment: Top
  HorizontalAlignment: Left
  MeshShadowMode: None
  ShadowColor: {x: 1.000000, y: 1.000000, z: 1.000000, w: 1.000000}
  ShadowDensity: 1.000000
  Text: |-
    Agent Center                                         
                                                            
     Manage AI coding agents in AR on Spectacles. Chat via 
     text or voice, attach images with hand gestures, and  
      see live agent status as 3D robot avatars pinned in
      your world.     
                                         
                                                          
      Requirements
    
      - Node.js 18+                                         
      - Git with LFS
      - Claude CLI, Codex CLI, or OpenClaw                  
                                                            
      Setup
                                                                                               
    
    1. Supabase backend                                   
      cd supabase && ./setup.sh
            
                                                    
    2. Start the Bridge                                 
      cd Bridge && npm install                              
      cp .env.example .env  # add your Supabase URL + key
      node sync.js                                          
                                     
                           
    3. Open in Lens Studio
      Open AgentCenter.esproj. To test without a backend,   
      set useMockData = true on AgentManagerController.     
       
    
    4. Deploy & Pair                                      
      Push the Lens to your Spectacles, then enter the    
      6-digit code from the Bridge terminal to pair.  
  Editable: false
  ShowEditingPreview: true
  TouchHandler: !<reference> 00000000-0000-0000-0000-000000000000
  SizeToFit: false
  FontSize: 60
  Font: !<reference> 00000000-0000-0000-0000-000000000000
  LayoutRect:
    left: -20.000000
    bottom: -2.250000
