    TextureStretch: FitWidth
  BlendMode: PremultipliedAlpha
  Outline: !<OutlineSettings>
    Enabled: false
    Fill: !<TextFill>
      Mode: Solid
      Color: {x: 0.000000, y: 0.000000, z: 0.000000, w: 1.000000}
      Texture: !<reference> 00000000-0000-0000-0000-000000000000
