  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">UIKit Sync Manager</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Syncs UIKit Sliders, TextInputField, and RectangleButton across a Connected Lens session.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Panel</span>"}'
    - '// @input SceneObject panelRoot {"hint":"Root SceneObject of the UI panel – disabled at start, enabled once the session is ready"}'
