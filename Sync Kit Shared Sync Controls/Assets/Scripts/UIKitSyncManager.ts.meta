    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Sync Text</span>"}'
    - '// @input AssignableType_3 inputField {"hint":"UIKit TextInputField whose content is synced across the session"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Sync Button</span>"}'
    - '// @input AssignableType_4 syncButton {"hint":"UIKit RectangleButton that broadcasts a click event to all users"}'
