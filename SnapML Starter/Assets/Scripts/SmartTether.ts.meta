    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">SmartTether – smart content tether</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Keeps content within distance thresholds of a target, smoothly repositioning as needed.</span>"}'
