    - '// @input vec3 offsetWithoutDetectedObject = {0,0,0} {"hint":"Offset applied when no detected object is present"}'
    - '// @input vec3 offsetWithDetectedObject = {0,0,0} {"hint":"Offset applied when a detected object is present"}'
