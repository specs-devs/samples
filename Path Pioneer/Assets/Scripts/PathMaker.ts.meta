  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">PathMaker – orchestrates path creation states</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Drives state transitions from start placement to path building to finish.</span>"}'
