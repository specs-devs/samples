  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">LineController – start/finish line manager</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Controls visuals, countdown, and collision events for path endpoint lines.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Visuals</span>"}'
    - '// @input SceneObject visualSo {"hint":"Root visual scene object for the line that can be repositioned"}'
    - '// @input SceneObject startVisual {"hint":"Scene object shown when this line acts as the start line"}'
    - '// @input SceneObject finishVisual {"hint":"Scene object shown when this line acts as the finish line"}'
    - '// @input SceneObject realVisualsParent {"hint":"Parent scene object for the final real-look visual assets"}'
    - '// @input SceneObject hintVisualsParent {"hint":"Parent scene object for the hint/preview visual assets"}'
    - '// @input SceneObject startLineTurnArrow {"hint":"Arrow shown on the start line indicating the turn direction"}'
    - '// @input SceneObject finishLineTurnArrow {"hint":"Arrow shown on the finish line indicating the turn direction"}'
    - '// @input SceneObject hintStartVisual {"hint":"Hint visual used when this line is in start position"}'
    - '// @input SceneObject hintFinishVisual {"hint":"Hint visual used when this line is in finish position"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Countdown</span>"}'
    - '// @input SceneObject countdownSo {"hint":"Root scene object shown during the walk countdown sequence"}'
    - '// @input SceneObject[] countdownSoArray {"hint":"Array of countdown digit scene objects shown in sequence"}'
    - '// @input Component.ColliderComponent countdownCollider {"hint":"Collider that detects the player standing inside the countdown zone"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Collision & Lap</span>"}'
    - '// @input Component.ColliderComponent camCol {"hint":"Collider attached to the camera used for line crossing detection"}'
    - '// @input Component.Text3D lapCounter3Dtext {"hint":"3D text showing the current lap number above the start line"}'
    - '// @input AssignableType pathCollisionEvents {"hint":"PathCollisionEvents component handling enter/exit collision callbacks"}'
    - '// @input AssignableType_1 pathWalker {"hint":"PathWalker notified when start area collision is detected"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
