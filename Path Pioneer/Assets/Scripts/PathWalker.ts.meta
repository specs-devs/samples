  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">PathWalker – runs the walking experience</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Tracks player pace, laps, and progress along the built path.</span>"}'
