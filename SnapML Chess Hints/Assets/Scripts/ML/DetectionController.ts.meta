  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">DetectionController – detection bounding box visualizer</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Instantiates and positions overlays for each detected chess piece.</span>"}'
