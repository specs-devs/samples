    - '// @input Asset.ObjectPrefab whiteLetter {"hint":"Prefab used to instantiate white piece label overlays"}'
    - '// @input Asset.ObjectPrefab blackLetter {"hint":"Prefab used to instantiate black piece label overlays"}'
