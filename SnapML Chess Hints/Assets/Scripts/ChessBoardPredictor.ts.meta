    - "// @input Component.Text hintButtonText {\"hint\":\"Text component on the hint button – updated to '...' while fetching and back to 'Get Hint' when done\"}"
    - '// @input AssignableType_4 resetButton {"hint":"UIKit RectangleButton that resets board alignment – shown on palm-up gesture"}'
