  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">ChessBoardPredictor – chess board detection and hint orchestration</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Processes ML detections, aligns board geometry, and requests AI move suggestions.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">AI Settings</span>"}'
    - '// @input bool useStockfish {"hint":"Use Stockfish API instead of Gemini for move suggestions"}'
    - '// @input float AISearchDepth = 8 {"hint":"Search depth for the Stockfish engine", "widget":"slider", "min":1, "max":12, "step":1, "showIf":"useStockfish"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Scene References</span>"}'
    - '// @input AssignableType cameraService {"hint":"Camera service that provides camera frames and pose data"}'
    - '// @input AssignableType_1 renderService {"hint":"Render service used to display board markers and move hints"}'
    - '// @input AssignableType_2 detectionController {"hint":"Detection controller that visualizes bounding boxes for detected pieces"}'
    - '// @input Component.Image debugImage {"hint":"Debug image overlay showing the ML model input frame"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Textures</span>"}'
    - '// @input Asset.Texture screenCropTexture {"hint":"Cropped camera texture fed into the ML model"}'
