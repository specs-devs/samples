  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">AirHockeyBitmojiController – Per-player bitmoji avatars with IK arm tracking</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Downloads and animates bitmoji avatars for both players using FABRIK inverse kinematics.</span>"}'
